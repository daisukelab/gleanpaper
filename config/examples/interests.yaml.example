version: 1

# ══════════════════════════════════════════════════════════════════════════════
# gleanpaper — interests.yaml
# ══════════════════════════════════════════════════════════════════════════════
# arXiv カテゴリ一覧: https://arxiv.org/category_taxonomy

# ── 取得設定 ──────────────────────────────────────────────────────────────────
fetch:
  categories:
    primary:                    # 重点カテゴリ（スコアボーナス 1.0）
      - cs.LG                   # Machine Learning
      - cs.CL                   # Computation and Language
      - cs.AI                   # Artificial Intelligence
    secondary:                  # 補助カテゴリ（スコアボーナス 0.7）
      - cs.CV                   # Computer Vision
      - cs.RO                   # Robotics
      - cs.NE                   # Neural and Evolutionary Computing
      - stat.ML                 # Machine Learning (Statistics)
  days_back: 1                  # 何日前まで遡るか（月曜は自動的に 3 に拡張）
  max_results: 500              # API 1回あたりの最大取得件数
  overlap_days: 2               # 増分フェッチで前回取得日より何日前まで遡るか（締め切り後投稿の遅延インデックス対策）

# ── スクリーニング設定 ────────────────────────────────────────────────────────
screening:
  min_score: 5                  # この未満は除外
  top_n: 50                     # スコア上位 N 件を保存

# ── 除外キーワード ────────────────────────────────────────────────────────────
# これらを含む論文はスコアに関わらず除外される
exclude_keywords:
  - "survey"
  - "tutorial"
  - "textbook"

# ══════════════════════════════════════════════════════════════════════════════
# トピック定義
# ──────────────────────────────────────────────────────────────────────────────
# - name    : トピック名（表示用）
# - tag     : タグ文字列（レビューファイルに suggested として表示、digest に記録）
# - weight  : スコアの重み（1〜10、高いほど優先）
# - enabled : false にすると一時的に無効化（キーワードを削除しなくてよい）
# - keywords: タイトル・アブストラクトを検索するキーワードリスト
#             大文字小文字は無視、フレーズマッチ対応
#             タイトルマッチはアブストラクトマッチの 2 倍の重みで計算
# ══════════════════════════════════════════════════════════════════════════════

topics:

  # ── Large Language Models ─────────────────────────────────────────────────
  - name: "Large Language Models"
    tag: "llm"
    weight: 10
    enabled: true
    keywords:
      - "large language model"
      - "LLM"
      - "language model"
      - "GPT"
      - "instruction tuning"
      - "instruction following"
      - "RLHF"
      - "reinforcement learning from human feedback"
      - "direct preference optimization"
      - "DPO"
      - "chain of thought"
      - "chain-of-thought"
      - "CoT"
      - "in-context learning"
      - "few-shot"
      - "zero-shot"
      - "prompt"
      - "prompting"
      - "tokenizer"
      - "pretraining"
      - "pre-training"
      - "fine-tuning"
      - "finetuning"
      - "RLVR"
      - "test-time compute"
      - "reasoning model"
      - "o1"
      - "deepseek"
      - "Llama"
      - "Mistral"
      - "Gemini"
      - "Claude"
      - "GPT-4"

  # ── Agents & Planning ─────────────────────────────────────────────────────
  - name: "Agents & Planning"
    tag: "agents"
    weight: 9
    enabled: true
    keywords:
      - "agent"
      - "multi-agent"
      - "tool use"
      - "tool calling"
      - "function calling"
      - "autonomous"
      - "agentic"
      - "planning"
      - "task planning"
      - "reasoning"
      - "chain-of-action"
      - "ReAct"
      - "self-play"
      - "self-improvement"
      - "self-reflection"
      - "workflow"
      - "orchestration"

  # ── Retrieval-Augmented Generation ────────────────────────────────────────
  - name: "RAG & Knowledge"
    tag: "rag"
    weight: 8
    enabled: true
    keywords:
      - "retrieval-augmented generation"
      - "RAG"
      - "retrieval augmented"
      - "knowledge retrieval"
      - "vector database"
      - "embedding retrieval"
      - "dense retrieval"
      - "knowledge base"
      - "knowledge graph"
      - "grounding"
      - "hallucination"
      - "factuality"
      - "long context"
      - "context window"

  # ── Multimodal ────────────────────────────────────────────────────────────
  - name: "Multimodal"
    tag: "multimodal"
    weight: 8
